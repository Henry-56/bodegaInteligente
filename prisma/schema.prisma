generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  STAFF
}

enum Channel {
  CHAT
  MANUAL
}

enum DebtStatus {
  OPEN
  PAID
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("")
  role         Role     @default(STAFF)
  createdAt    DateTime @default(now())

  warehouses   Warehouse[]
  purchases    Purchase[]
  sales        Sale[]
  chatEvents   ChatEvent[]
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())

  products   Product[]
  purchases  Purchase[]
  sales      Sale[]
  debtors    Debtor[]
  chatEvents ChatEvent[]
}

model Product {
  id               String   @id @default(cuid())
  warehouseId      String
  warehouse        Warehouse @relation(fields: [warehouseId], references: [id])
  name             String
  salePriceDefault Decimal? @db.Decimal(12, 4)
  createdAt        DateTime @default(now())

  inventory     Inventory?
  purchaseItems PurchaseItem[]
  saleItems     SaleItem[]

  @@unique([warehouseId, name])
}

model Inventory {
  productId   String  @id
  product     Product @relation(fields: [productId], references: [id])
  qtyOnHand   Int     @default(0)
  avgUnitCost Decimal @default(0) @db.Decimal(12, 4)
}

model Purchase {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  vendorName  String?
  purchasedAt DateTime  @default(now())
  total       Decimal?  @db.Decimal(12, 4)
  imagePath   String?
  rawOcrText  String?
  confirmed   Boolean   @default(false)

  items PurchaseItem[]
}

model PurchaseItem {
  id              String  @id @default(cuid())
  purchaseId      String
  purchase        Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product? @relation(fields: [productId], references: [id])
  productNameText String
  qty             Int
  unitCost        Decimal @db.Decimal(12, 4)
  subtotal        Decimal @db.Decimal(12, 4)
}

model Sale {
  id          String   @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  soldAt      DateTime @default(now())
  total       Decimal? @db.Decimal(12, 4)
  channel     Channel  @default(MANUAL)

  items SaleItem[]
}

model SaleItem {
  id               String  @id @default(cuid())
  saleId           String
  sale             Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId        String
  product          Product @relation(fields: [productId], references: [id])
  qty              Int
  unitPrice        Decimal @db.Decimal(12, 4)
  unitCostSnapshot Decimal @db.Decimal(12, 4)
  profit           Decimal @db.Decimal(12, 4)
}

model Debtor {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  name        String
  phone       String?
  createdAt   DateTime  @default(now())

  debts Debt[]

  @@unique([warehouseId, name])
}

model Debt {
  id        String     @id @default(cuid())
  debtorId  String
  debtor    Debtor     @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  amount    Decimal    @db.Decimal(12, 4)
  note      String?
  imagePath String?
  status    DebtStatus @default(OPEN)

  payments DebtPayment[]
}

model DebtPayment {
  id     String   @id @default(cuid())
  debtId String
  debt   Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  paidAt DateTime @default(now())
  amount Decimal  @db.Decimal(12, 4)
}

model ChatEvent {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  text        String
  intent      String?
  resultJson  String?
  createdAt   DateTime  @default(now())
}
